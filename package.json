{
    "name": "tools-app",
    "version": "1.0.0",
    "main": "electron-main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder"
    },
    "devDependencies": {
        "electron": "^30.5.1",
        "electron-builder": "^26.8.1"
    },
    "build": {
        "appId": "com.tzhousensei.noveltool",
        "productName": "NovelTool",
        "files": [
            "**/*"
        ],
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": "nsis"
        },
        "mac": {
            "target": "dmg"
        },
        "linux": {
            "target": "AppImage"
        }
    },
    "description": "",
    "keywords": [],
    "author": "",
    "license": "ISC"
}
